# Copy to .env.local and fill in values. Never commit secrets.

# Hjelpi Supabase project URL (replace if you use a different project):
# https://xbmqtwvlfwmtptgrlxxt.supabase.co

# Supabase Auth: add redirect URLs in the Supabase dashboard (Auth → URL configuration):
# - http://localhost:3000/no/auth/callback
# - https://<your-domain>/no/auth/callback
# (PKCE: e-post for bekreftelse og tilbakestilling går hit først, deretter til min-konto / tilbakestill-passord.)
# Set NEXT_PUBLIC_BASE_URL for lenker i e-poster (same host as the app).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_TAX_RATE_ID=

NEXT_PUBLIC_MAPBOX_TOKEN=

TYPESENSE_HOST=
TYPESENSE_API_KEY=
NEXT_PUBLIC_TYPESENSE_SEARCH_KEY=

CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
NEXT_PUBLIC_R2_PUBLIC_URL=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

RESEND_API_KEY=
RESEND_FROM_EMAIL=

TRIGGER_API_KEY=

SIGNICAT_CLIENT_ID=
SIGNICAT_CLIENT_SECRET=
SIGNICAT_ENVIRONMENT=

NEXT_PUBLIC_POSTHOG_KEY=
# Ingestion API (default https://eu.i.posthog.com). Use https://us.i.posthog.com for US cloud. /ingest proxy can hit HTTP 431 with large cookies.
NEXT_PUBLIC_POSTHOG_HOST=
# Optional; inferred from POSTHOG_HOST when unset (eu.posthog.com vs us.posthog.com).
NEXT_PUBLIC_POSTHOG_UI_HOST=
# Set to 1 to skip remote config / feature-flag API calls (silences [RemoteConfig] errors when blocked by network or ad blockers).
NEXT_PUBLIC_POSTHOG_DISABLE_FLAGS=
SENTRY_DSN=
NEXT_PUBLIC_BASE_URL=

COOKIEBOT_ID=
